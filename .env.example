# .env.example — commit this file to GitHub, never commit .env
#
# Copy this file to .env and adjust values if needed:
#   cp .env.example .env
#
# All values below are safe local defaults that work out of the box
# with docker-compose.yml / docker-compose.friend.yml.

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=siteforge_dev
DB_USERNAME=siteforge
DB_PASSWORD=localpassword

# Used by the Spring Boot backend (override in docker-compose via environment:)
DB_URL=jdbc:postgresql://localhost:5432/siteforge_dev?TimeZone=UTC

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origins allowed to call the API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: change JWT_SECRET to a long random string before deploying to production
JWT_SECRET=change-this-to-a-long-random-secret-before-going-to-production

# Access token lifetime: 15 minutes (in milliseconds)
JWT_EXPIRY_MS=900000

# Refresh token lifetime: 7 days (in milliseconds)
JWT_REFRESH_EXPIRY_MS=604800000
