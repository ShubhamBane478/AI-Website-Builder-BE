# Copy this file to .env for local dev, or to .env.uat for Oracle Cloud VM.
# Never commit .env or .env.uat — they contain real credentials.

# ─── Database (Neon.tech) ────────────────────────────────────────────────────
# Local dev  → use your Neon "dev" branch connection string
# UAT/Oracle → use your Neon "main" branch connection string
DB_URL=jdbc:postgresql://ep-XXXX.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your-neon-password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters.
JWT_SECRET=change-this-to-a-random-32-char-string
# JWT_EXPIRY_MS=900000
# JWT_REFRESH_EXPIRY_MS=604800000

# ─── CORS (UAT/Oracle Cloud only) ────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
